# Copy to .env. All values below are safe local defaults; the scaffold runs without secrets.

# --- Database ---
POSTGRES_USER=meridian
POSTGRES_PASSWORD=meridian
POSTGRES_DB=meridian
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full URL used by the backend. When running locally without Docker, set host to localhost.
DATABASE_URL=postgresql+psycopg2://meridian:meridian@db:5432/meridian

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- LLM gateway (STUB) ---
# The scaffold ships a stub gateway that returns canned text and requires NO keys.
# When wiring LiteLLM, set the provider/model here. LLM_MODE=stub keeps everything offline.
LLM_MODE=stub
# Example real values (unused while LLM_MODE=stub):
# LLM_MODE=live
# LLM_MODEL=anthropic/claude-opus-4-7
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Simulation defaults ---
DEFAULT_SEED=88213
